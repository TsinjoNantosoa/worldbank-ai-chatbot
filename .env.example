# World Bank Chatbot - Environment Variables
# Copy this file to .env and fill in your values

# OpenAI API Key (REQUIRED)
OPENAI_API_KEY=sk-your-api-key-here

# Model Configuration (OPTIONAL - overrides config.json)
WB_MODEL=gpt-4o-mini
WB_TEMPERATURE=0.0
WB_MAX_TOKENS=1500

# Server Configuration (OPTIONAL)
WB_SERVER_HOST=0.0.0.0
WB_SERVER_PORT=8000

# Vector Store (OPTIONAL)
WB_EMBEDDING_MODEL=text-embedding-3-large
WB_FAISS_PATH=./data/faiss_index

# Data Collection (OPTIONAL)
WB_DATA_FILE=./data/world_bank_data.json
